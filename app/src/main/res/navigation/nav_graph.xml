<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/splashFragment">

    <fragment android:id="@+id/splashFragment"
        android:name="com.raktavahini.ui.auth.SplashFragment"
        android:label="Splash">
        <action android:id="@+id/action_splash_to_login" app:destination="@id/loginFragment" app:popUpTo="@id/nav_graph" app:popUpToInclusive="true"/>
        <action android:id="@+id/action_splash_to_home" app:destination="@id/homeFragment" app:popUpTo="@id/nav_graph" app:popUpToInclusive="true"/>
        <action android:id="@+id/action_splash_to_profile_setup" app:destination="@id/editProfileFragment" app:popUpTo="@id/nav_graph" app:popUpToInclusive="true"/>
    </fragment>

    <fragment android:id="@+id/loginFragment"
        android:name="com.raktavahini.ui.auth.LoginFragment"
        android:label="Login">
        <action android:id="@+id/action_login_to_register" app:destination="@id/registerFragment"/>
        <action android:id="@+id/action_login_to_home" app:destination="@id/homeFragment" app:popUpTo="@id/nav_graph" app:popUpToInclusive="true"/>
        <action android:id="@+id/action_login_to_profile_setup" app:destination="@id/editProfileFragment" app:popUpTo="@id/nav_graph" app:popUpToInclusive="true"/>
    </fragment>

    <fragment android:id="@+id/registerFragment"
        android:name="com.raktavahini.ui.auth.RegisterFragment"
        android:label="Register">
        <action android:id="@+id/action_register_to_login" app:destination="@id/loginFragment" app:popUpTo="@id/registerFragment" app:popUpToInclusive="true"/>
        <action android:id="@+id/action_register_to_profile_setup" app:destination="@id/editProfileFragment" app:popUpTo="@id/nav_graph" app:popUpToInclusive="true"/>
    </fragment>

    <fragment android:id="@+id/homeFragment"
        android:name="com.raktavahini.ui.home.HomeFragment"
        android:label="Home">
        <action android:id="@+id/action_home_to_search" app:destination="@id/searchFragment"/>
        <action android:id="@+id/action_home_to_profile" app:destination="@id/profileFragment"/>
        <action android:id="@+id/action_home_to_log" app:destination="@id/logFragment"/>
    </fragment>

    <fragment android:id="@+id/searchFragment"
        android:name="com.raktavahini.ui.search.SearchFragment"
        android:label="Emergency Search"/>

    <fragment android:id="@+id/profileFragment"
        android:name="com.raktavahini.ui.profile.ProfileFragment"
        android:label="My Profile">
        <action android:id="@+id/action_profile_to_edit" app:destination="@id/editProfileFragment"/>
        <action android:id="@+id/action_profile_to_login" app:destination="@id/loginFragment" app:popUpTo="@id/nav_graph" app:popUpToInclusive="true"/>
    </fragment>

    <fragment android:id="@+id/editProfileFragment"
        android:name="com.raktavahini.ui.profile.EditProfileFragment"
        android:label="Edit Profile">
        <argument
            android:name="isSetup"
            app:argType="boolean"
            android:defaultValue="false" />
        <action android:id="@+id/action_edit_to_home" app:destination="@id/homeFragment" app:popUpTo="@id/editProfileFragment" app:popUpToInclusive="true"/>
    </fragment>

    <fragment android:id="@+id/logFragment"
        android:name="com.raktavahini.ui.log.LogFragment"
        android:label="Donation Log"/>

    <fragment android:id="@+id/aiFragment"
        android:name="com.raktavahini.ui.ai.AiFragment"
        android:label="Ask AI"/>
</navigation>
