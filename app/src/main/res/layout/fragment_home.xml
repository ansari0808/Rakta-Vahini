<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Hero Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tvBrand"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_name"
                    android:textColor="@color/red_primary"
                    android:textSize="11sp"
                    android:letterSpacing="0.1"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginTop="8dp"/>

                <TextView
                    android:id="@+id/tvGreeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Welcome,\nMd Mohiuddin Ansari 👋"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnBackground"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLanguage"
                    style="@style/Widget.Material3.Button.IconButton"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    app:icon="@drawable/ic_translate"
                    app:iconSize="24dp"
                    app:iconPadding="0dp"
                    android:backgroundTint="@android:color/transparent"
                    app:rippleColor="@color/red_primary"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnThemeToggle"
                    style="@style/Widget.Material3.Button.IconButton"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    app:iconSize="24dp"
                    app:iconPadding="0dp"
                    android:backgroundTint="@android:color/transparent"
                    app:rippleColor="@color/red_primary"/>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvBloodGroup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="O+"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:background="@drawable/bg_blood_group"
                android:paddingHorizontal="14dp"
                android:paddingVertical="6dp"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipEligible"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home_eligible_status"
                android:textColor="@android:color/white"
                android:layout_marginStart="10dp"
                app:chipBackgroundColor="@color/green_eligible"
                app:chipCornerRadius="20dp"/>
        </LinearLayout>

        <!-- Quick Actions -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="20dp"
            android:weightSum="3">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnEmergency"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="?attr/colorSurface">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:gravity="center" android:padding="14dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🚨" android:textSize="22sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/home_action_emergency" android:textSize="11sp" android:textColor="?attr/colorOnSurfaceVariant"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnProfile"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="3dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="?attr/colorSurface">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:gravity="center" android:padding="14dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="👤" android:textSize="22sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/home_action_profile" android:textSize="11sp" android:textColor="?attr/colorOnSurfaceVariant"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnLog"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="?attr/colorSurface">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:gravity="center" android:padding="14dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="📋" android:textSize="22sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/home_action_log" android:textSize="11sp" android:textColor="?attr/colorOnSurfaceVariant"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- SOS Banner -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardCornerRadius="14dp"
            app:cardBackgroundColor="@color/sos_background"
            app:strokeColor="@color/sos_border"
            app:strokeWidth="1dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="14dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/home_sos_title" android:textColor="@color/red_primary"
                    android:textStyle="bold" android:textSize="13sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/home_sos_desc"
                    android:textColor="@color/sos_text" android:textSize="12sp" android:layout_marginTop="4dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Stats -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/home_label_stats" android:textSize="10sp" android:letterSpacing="0.1"
            android:textColor="?attr/colorOnSurfaceVariant" android:layout_marginTop="20dp"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginTop="8dp" android:weightSum="2">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:layout_marginEnd="6dp"
                app:cardCornerRadius="14dp" app:cardBackgroundColor="?attr/colorSurface">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:gravity="center" android:padding="14dp">
                    <TextView android:id="@+id/tvDonationCount"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textSize="28sp" android:textStyle="bold"
                        android:textColor="@color/red_primary"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/home_label_donations" android:textSize="11sp" android:textColor="?attr/colorOnSurfaceVariant"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:layout_marginStart="6dp"
                app:cardCornerRadius="14dp" app:cardBackgroundColor="?attr/colorSurface">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:gravity="center" android:padding="14dp">
                    <TextView android:id="@+id/tvNearbyCount"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textSize="28sp" android:textStyle="bold"
                        android:textColor="@color/red_primary"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/home_label_nearby" android:textSize="11sp" android:textColor="?attr/colorOnSurfaceVariant"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Last Donation -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/home_label_last_donation" android:textSize="10sp" android:letterSpacing="0.1"
            android:textColor="?attr/colorOnSurfaceVariant" android:layout_marginTop="20dp"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="8dp" android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp" app:cardBackgroundColor="?attr/colorSurface">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:padding="16dp" android:gravity="center_vertical">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:id="@+id/tvLastDonationDate"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textSize="14sp" android:textStyle="bold"
                        android:textColor="?attr/colorOnBackground"/>
                    <TextView android:id="@+id/tvLastDonationCenter"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="No donations yet" android:textSize="12sp"
                        android:textColor="?attr/colorOnSurfaceVariant" android:layout_marginTop="2dp"/>
                </LinearLayout>
                <TextView android:id="@+id/tvDaysAgo"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="" android:textSize="13sp" android:textStyle="bold"
                    android:textColor="@color/green_eligible"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
